# ── UTM Webmaster Tool — Deployment Credentials ─────────────────────────
# Copy this file to .env and fill in the actual passwords.
# This file is gitignored — never commit secrets.
#
# Format: UTM_FTP_{SITE_UPPERCASE}_PASSWORD=actual_password
#
# Examples:
# UTM_FTP_CHANCELLERY_PASSWORD=
# UTM_FTP_KL_PASSWORD=
# UTM_FTP_PHOTOS_PASSWORD=
# UTM_FTP_INTERNATIONAL_PASSWORD=
